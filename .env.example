# Hippocampus Configuration

# Server
PORT=3000
HOST=0.0.0.0

# Database encryption passphrase (REQUIRED)
# Generate a strong passphrase: openssl rand -base64 32
HIPPO_PASSPHRASE=

# Database path (default: ./data/hippocampus.db)
HIPPO_DB_PATH=./data/hippocampus.db

# Rate limiting
RATE_LIMIT_REMEMBER=20
RATE_LIMIT_RECALL=60

# Optional: Bearer token for local testing (skip OAuth)
# Leave empty to disable token auth
HIPPO_TOKEN=

# Optional: Agent bearer token for machine-to-machine access.
# Works alongside OAuth — OAuth clients are checked first, then this token.
# Use for scheduled agents running on your own infrastructure.
# Generate: openssl rand -hex 32
# Minimum 32 characters enforced at startup.
# HIPPO_AGENT_TOKEN=

# Embedding model cache directory (default: system cache)
# TRANSFORMERS_CACHE=./data/.models

# OAuth 2.1 (required for remote MCP access via Claude.ai, ChatGPT, etc.)
# Set HIPPO_OAUTH_ISSUER to your server's public URL to enable OAuth
# Generate password hash:
# echo -n 'your-password' | openssl dgst -sha256 -binary | openssl base64 -A | tr '+/' '-_' | tr -d '='
# HIPPO_OAUTH_ISSUER=https://hippo.yourdomain.com
# HIPPO_OAUTH_USER=admin
# HIPPO_OAUTH_PASSWORD_HASH=
